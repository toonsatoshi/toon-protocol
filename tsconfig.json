{
    "compilerOptions": {
        "target": "ESNext",
        "module": "CommonJS",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "types": ["jest", "node"],
        "baseUrl": ".",
        "rootDir": ".",
        "ignoreDeprecations": "6.0",
        "paths": {
            "*": ["node_modules/*"]
        }
    },
    "include": ["src/**/*", "tests/**/*", "build/**/*"]
}
