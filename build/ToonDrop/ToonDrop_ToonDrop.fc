            throw_unless(48799, ( equal_slices_bits(__tact_context_get_sender(), $self'artist) ));
            throw_unless(57653, $self'isLocked);
            int $balance = $global_myBalance();
            int $safeToWithdraw = ($balance - 50000000);
            throw_unless(25836, ($safeToWithdraw > 0));
            $global_send($SendParameters$_constructor_to_value_mode_body($msg'recipient, $safeToWithdraw, 2, __gen_cell_cell_a2de1b40ab66def3b5938bd2624eff638ae538c437890a9720b8dc0470084ae7()));
            $ToonDrop$_contract_store(($self'artist, $self'trackId, $self'registry, $self'vault, $self'royaltyPercentage, $self'raiseTarget, $self'slicePrice, $self'deadline, $self'currentRaise, $self'isLocked, $self'isSuccessful, $self'investorCount, $self'investments, $self'totalRoyaltiesReceived, $self'claimedRoyalties));
            return ();
        }
        
        ;; Receive Deploy message
        if (op == 0x946a98b6) {
            var $deploy'queryId = in_msg~load_uint(64);
            ($self'artist, $self'trackId, $self'registry, $self'vault, $self'royaltyPercentage, $self'raiseTarget, $self'slicePrice, $self'deadline, $self'currentRaise, $self'isLocked, $self'isSuccessful, $self'investorCount, $self'investments, $self'totalRoyaltiesReceived, $self'claimedRoyalties)~$ToonDrop$_fun_notify($DeployOk$_store_cell($DeployOk$_constructor_queryId($deploy'queryId), begin_cell()));
            $ToonDrop$_contract_store(($self'artist, $self'trackId, $self'registry, $self'vault, $self'royaltyPercentage, $self'raiseTarget, $self'slicePrice, $self'deadline, $self'currentRaise, $self'isLocked, $self'isSuccessful, $self'investorCount, $self'investments, $self'totalRoyaltiesReceived, $self'claimedRoyalties));
            return ();
        }
        
    }
    ;; Empty Receiver and Text Receivers
    var text_op = slice_hash(in_msg);
    ;; Receive "CheckDeadline" message
    if (text_op == 0xaeed1ccdf669775eaacb65b293ce27fb10dc5d8c9e1f702d7dd1608a36d7c84d) {
        if (( ((~ $self'isLocked)) ? (($global_now() > $self'deadline)) : (false) )) {
            ($self'artist, $self'trackId, $self'registry, $self'vault, $self'royaltyPercentage, $self'raiseTarget, $self'slicePrice, $self'deadline, $self'currentRaise, $self'isLocked, $self'isSuccessful, $self'investorCount, $self'investments, $self'totalRoyaltiesReceived, $self'claimedRoyalties)~$ToonDrop$_fun_finalize(($self'currentRaise >= $self'raiseTarget));
