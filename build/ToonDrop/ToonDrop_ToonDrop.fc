            slice $investor = __tact_context_get_sender();
            int $invested = __tact_dict_get_slice_int($self'investments, 267, $investor, 257);
            throw_unless(41896, ( ((~ null?($invested))) ? ((__tact_not_null($invested) > 0)) : (false) ));
            int $refundAmount = __tact_not_null($invested);
            $self'investments~__tact_dict_set_slice_int(267, $investor, 0, 257);
            $global_send($SendParameters$_constructor_to_value_mode_body($investor, $refundAmount, 2, __gen_cell_cell_a41f82e898c3a23c8740c9c5bcdaae6d00ab315ee3df6bb7d8d8f03227438bae()));
            $ToonDrop$_contract_store(($self'artist, $self'trackId, $self'registry, $self'vault, $self'royaltyPercentage, $self'raiseTarget, $self'slicePrice, $self'deadline, $self'currentRaise, $self'isLocked, $self'isSuccessful, $self'investorCount, $self'investments, $self'totalRoyaltiesReceived, $self'claimedRoyalties));
