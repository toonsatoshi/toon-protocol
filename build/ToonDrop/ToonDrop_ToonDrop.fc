    build_1 = build_1.store_uint(v'investorCount, 32);
    build_1 = build_1.store_dict(v'investments);
    build_1 = build_1.store_varuint16(v'totalRoyaltiesReceived);
    build_1 = build_1.store_dict(v'claimedRoyalties);
    build_0 = store_builder_ref(build_0, build_1);
