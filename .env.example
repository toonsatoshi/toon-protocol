# ── Oracle Signing Key ───────────────────────────────────────
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Store the public key in the vault on deploy (see deployToonProtocol.ts).
# NEVER commit this value. Rotate via vault.SetOracleKey if compromised.
ORACLE_SEED_HEX=

